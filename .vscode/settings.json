{
  // Playwright Test 확장 설정
  "playwright.reuseBrowser": true,
  "playwright.showTrace": false,
  // VS Code Test Explorer는 ~/.zshrc 환경변수를 상속받지 않으므로,
  // stage 환경 기본값을 명시 주입해 playwright.config.ts의 isSTG 분기와
  // stg-auth.json 자동 로드를 보장한다. prod 실행 시 터미널에서
  // MAKESTAR_BASE_URL=https://www.makestar.com 으로 오버라이드.
  "playwright.env": {
    "MAKESTAR_BASE_URL": "https://stage-new.makeuni2026.com"
  },

  // 테스트 탐색기 설정
  "testing.automaticallyOpenPeekView": "never",
  "testing.defaultGutterClickAction": "run",

  // TypeScript 설정
  "typescript.preferences.importModuleSpecifier": "relative"
}
