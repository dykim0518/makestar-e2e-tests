  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25.0.3",
    "adm-zip": "^0.5.17",
    "typescript": "^6.0.2",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}
